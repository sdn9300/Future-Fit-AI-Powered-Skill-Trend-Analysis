# ── Phase 2: Configuration Architecture ──────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it contains real credentials.

# Groq API — LLM for email generation
# Get your API key from https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Sending method: 'gmail_api' or 'smtp'
EMAIL_METHOD=gmail_api

# Sender identity — used in email headers
SENDER_NAME=Your Name
SENDER_EMAIL=you@example.com

# Safety flags
DRY_RUN=true
MAX_CONTACTS=10
USE_LLM=true

# SMTP settings (only used if EMAIL_METHOD=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=

# App metadata
NEXT_PUBLIC_APP_NAME=Overture - Cold Email Agent
